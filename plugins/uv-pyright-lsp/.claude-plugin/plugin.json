{
  "name": "uv-pyright-lsp",
  "version": "0.1.0",
  "description": "Pyright LSP server launched via uv run for project-specific Python type checking",
  "author": {
    "name": "OneDragon",
    "email": "one-dragon@example.com"
  },
  "homepage": "https://github.com/OneDragon-Anything/OneDragon-CC-Plugins",
  "repository": "https://github.com/OneDragon-Anything/OneDragon-CC-Plugins",
  "license": "MIT",
  "keywords": [
    "python",
    "pyright",
    "lsp",
    "type-checking",
    "uv"
  ],
  "lspServers": {
    "uv-pyright": {
      "command": "uv",
      "args": [
        "run",
        "pyright-langserver",
        "--stdio"
      ],
      "extensionToLanguage": {
        ".py": "python",
        ".pyi": "python"
      }
    }
  }
}
